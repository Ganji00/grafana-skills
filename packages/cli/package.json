{
  "name": "grafana-skills",
  "version": "0.1.0",
  "description": "Install Grafana AI agent skills into your project",
  "bin": {
    "grafana-skills": "./bin/cli.mjs"
  },
  "files": [
    "bin/",
    "dist/"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "picocolors": "^1.1.0",
    "tar": "^7.0.0",
    "@opentelemetry/sdk-metrics": "^1.30.0",
    "@opentelemetry/exporter-metrics-otlp-http": "~0.213.0",
    "@opentelemetry/resources": "^1.30.0",
    "@opentelemetry/semantic-conventions": "^1.30.0"
  },
  "devDependencies": {
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.1.0",
    "@types/node": "24.12.0",
    "@types/tar": "7.0.87"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "grafana",
    "ai",
    "skills",
    "agent-skills",
    "claude",
    "cursor"
  ],
  "homepage": "https://github.com/grafana/skills",
  "repository": {
    "type": "git",
    "url": "https://github.com/grafana/skills.git"
  },
  "license": "Apache-2.0"
}
